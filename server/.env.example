NODE_ENV=development
PORT=5002

# MongoDB Atlas (Shivam Traders cluster)
# Copy this file to .env and replace YOUR_DB_PASSWORD with the password shared by Shivam
MONGODB_URI=mongodb+srv://YOUR_DB_USER:YOUR_DB_PASSWORD@YOUR_CLUSTER.mongodb.net/shivam_traders?retryWrites=true&w=majority&appName=Cluster0

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=30d

# Cloudinary (add when ready for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Razorpay (add when ready for payments)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Email (Nodemailer - optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL=Shivam Traders <noreply@shivamtraders.com>
FROM_NAME=Shivam Traders

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# Admin login (created when you run npm run seed)
ADMIN_EMAIL=your_admin@example.com
ADMIN_PASSWORD=***REMOVED***
